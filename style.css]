/* Reset básico */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: Arial, sans-serif;
    line-height: 1.6;
    background-color: #f0f9f0;
    color: #2e2e2e;
    padding: 20px;
}

header {
    text-align: center;
    margin-bottom: 30px;
}

.logo {
    width: 100px;
    margin-bottom: 10px;
}

h1 {
    color: #2a7f2a;
}

main {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
}

.intro {
    max-width: 600px;
    text-align: center;
}

.atividade {
    background-color: #d9f2d9;
    padding: 20px;
    border-radius: 10px;
    width: 100%;
    max-width: 400px;
    text-align: center;
}

input {
    width: 60%;
    padding: 8px;
    margin: 10px 0;
}

button {
    padding: 10px 20px;
    background-color: #2a7f2a;
    color: white;
    border: none;
    cursor: pointer;
    border-radius: 5px;
}

button:hover {
    background-color: #1e5e1e;
}

#resultado {
    margin-top: 15px;
    font-weight: bold;
    color: #1e5e1e;
}

footer {
    margin-top: 40px;
    text-align: center;
    font-size: 0.9em;
    color: #555;
}

/* Responsividade */
@media (max-width: 500px) {
    input {
        width: 100%;
    }

    .atividade {
        padding: 15px;
    }
}